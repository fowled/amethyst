{{#equal error 403}}
    {{setVar "errorMsg" "403: forbidden access"}}
{{else equal error 404}}
    {{setVar "errorMsg" "404: the link does not exist."}}
{{else equal error 500}}
    {{setVar "errorMsg" "500: This link name is not available."}}
{{else equal error 200}}
    {{setVar "errorMsg" "200: your link was successfully created!"}}
{{/equal}}

<br>
<container>
    <article class="message {{color}}" style="width: 20%; margin-right: auto; margin-left: auto" id="visibility">
        <div class="message-body">{{errorMsg}} {{url}}</div>
    </article>
</container>